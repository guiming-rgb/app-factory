                Row(
                  children: [
                    Text(
                      '¥${price.toStringAsFixed(2)}',
                      style: TextStyle(
                        fontSize: 16,
                        fontWeight: FontWeight.bold,
                        color: primaryColor,
                      ),
                    ),
                    const SizedBox(width: 8),
                    Text(
                      '月售 $salesCount',
                      style: TextStyle(
                        fontSize: 12,
                        color: colorScheme.onSurfaceVariant,
                      ),
                    ),
                    const Spacer(),
                    IconButton.filled(
                      onPressed: onAddToCart,
                      icon: const Icon(Icons.add, size: 20),
                      style: IconButton.styleFrom(
                        minimumSize: const Size(32, 32),
                      ),
                    ),
                  ],
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}

class OrderStatusTracker extends StatelessWidget {
  final int currentStage; // 0-3
  final List<String> stageLabels;

  const OrderStatusTracker({
    super.key,
    required this.currentStage,
    this.stageLabels = const ['已下单', '商家接单', '骑手取餐', '送达'],
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;
    final primaryColor = colorScheme.primary;

    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 16, horizontal: 24),
      child: Row(
        children: List.generate(stageLabels.length * 2 - 1, (index) {
          if (index.isOdd) {
            final stageIndex = index ~/ 2;
            final isCompleted = stageIndex < currentStage;
            return Expanded(
              child: Container(
                height: 3,
                decoration: BoxDecoration(
                  color: isCompleted ? primaryColor : Colors.grey[300],
                  borderRadius: BorderRadius.circular(1.5),
                ),
              ),
            );
          }
          final stageIndex = index ~/ 2;
          final isActive = stageIndex <= currentStage;
          final icons = [
            Icons.receipt_long_outlined,
            Icons.restaurant_outlined,
            Icons.pedal_bike_outlined,
            Icons.check_circle_outline,
          ];

          return Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              Container(
                width: 36,
                height: 36,
                decoration: BoxDecoration(
                  color: isActive ? primaryColor : Colors.grey[300],
                  shape: BoxShape.circle,
                ),
                child: Icon(
                  icons[stageIndex],
                  size: 20,
                  color: isActive ? Colors.white : Colors.grey[600],
                ),
              ),
              const SizedBox(height: 6),
              Text(
                stageLabels[stageIndex],
                style: TextStyle(
                  fontSize: 11,
                  fontWeight: isActive ? FontWeight.w600 : FontWeight.normal,
                  color: isActive ? primaryColor : Colors.grey[500],
                ),
              ),
            ],
          );
        }),
      ),
    );
  }
}

class CouponCard extends StatelessWidget {
  final double amount;
  final String minOrderCondition;
  final VoidCallback? onClaim;

  const CouponCard({
    super.key,
    required this.amount,
    required this.minOrderCondition,
    this.onClaim,
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return Card(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 6),
      clipBehavior: Clip.antiAlias,
      child: Container(
        decoration: const BoxDecoration(
          gradient: LinearGradient(
            colors: [Color(0xFFFF8C00), Color(0xFFFFA500)],
            begin: Alignment.topLeft,
            end: Alignment.bottomRight,
          ),
        ),
        child: Padding(
          padding: const EdgeInsets.all(16),
          child: Row(
            children: [
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      children: [
                        Text(
                          '¥',
                          style: TextStyle(
                            fontSize: 16,
                            fontWeight: FontWeight.bold,
                            color: colorScheme.onPrimary,
                          ),
                        ),
                        Text(
                          '${amount.toStringAsFixed(0)}',
                          style: TextStyle(
                            fontSize: 36,
                            fontWeight: FontWeight.bold,
                            color: colorScheme.onPrimary,
                          ),
                        ),
                      ],
                    ),
                    const SizedBox(height: 4),
                    Text(
                      minOrderCondition,
                      style: TextStyle(
                        fontSize: 13,
                        color: colorScheme.onPrimary.withOpacity(0.85),
                      ),
                    ),
                  ],
                ),
              ),
              FilledButton(
                onPressed: onClaim,
                style: FilledButton.styleFrom(
                  backgroundColor: Colors.white,
                  foregroundColor: Colors.orange,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(20),
                  ),
                ),
                child: const Text('领取'),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
