import 'package:flutter/material.dart';
import '../../../core/theme/app_theme.dart';

/// {{industry}} social widgets for {{displayName}} app.
/// Uses {{primaryColor}} as the accent color.

class PostCard extends StatelessWidget {
  final String avatarUrl;
  final String userName;
  final String content;
  final List<String> imageUrls;
  final int likeCount;
  final int commentCount;
  final int shareCount;
  final bool isLiked;
  final VoidCallback onLike;
  final VoidCallback onComment;
  final VoidCallback onShare;

  const PostCard({
    super.key,
    required this.avatarUrl,
    required this.userName,
    required this.content,
    this.imageUrls = const [],
    this.likeCount = 0,
    this.commentCount = 0,
    this.shareCount = 0,
    this.isLiked = false,
    required this.onLike,
    required this.onComment,
    required this.onShare,
  });

  int get _imageColumnCount {
    if (imageUrls.isEmpty) return 1;
    if (imageUrls.length == 1) return 1;
    if (imageUrls.length <= 4) return 2;
    return 3;
  }

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return Semantics(label: 'Post by $userName', child: Card(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 6),
      child: Padding(
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            _buildUserHeader(colorScheme),
            const SizedBox(height: 12),
            _buildContent(),
            if (imageUrls.isNotEmpty) ...[
              const SizedBox(height: 12),
              _buildImageGrid(),
            ],
            const SizedBox(height: 12),
            _buildInteractionBar(colorScheme),
          ],
        ),
      ),
    ));
  }

  Widget _buildUserHeader(ColorScheme colorScheme) {
    return Row(
      children: [
        Semantics(label: 'Avatar of $userName', child: CircleAvatar(
          radius: 20,
          backgroundImage: NetworkImage(avatarUrl),
          onBackgroundImageError: (_, __) {},
        )),
        const SizedBox(width: 12),
        Expanded(
          child: Text(
            userName,
            style: TextStyle(
              fontWeight: FontWeight.w600,
              fontSize: 15,
              color: colorScheme.onSurface,
            ),
          ),
        ),
      ],
    );
  }

  Widget _buildContent() {
    return Text(
      content,
      maxLines: 5,
      overflow: TextOverflow.ellipsis,
      style: const TextStyle(fontSize: 14, height: 1.5),
    );
  }

  Widget _buildImageGrid() {
    final columnCount = _imageColumnCount;
    final crossAxisCount = columnCount;

    return ClipRRect(
      borderRadius: BorderRadius.circular(12),
      child: GridView.builder(
        shrinkWrap: true,
        physics: const NeverScrollableScrollPhysics(),
        gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
          crossAxisCount: crossAxisCount,
          mainAxisSpacing: 2,
          crossAxisSpacing: 2,
          childAspectRatio: columnCount == 1 ? 16 / 9 : 1,
        ),
        itemCount: imageUrls.length,
        itemBuilder: (context, index) {
          return Image.network(
            imageUrls[index],
            fit: BoxFit.cover,
            errorBuilder: (_, __, ___) => Container(
              color: Colors.grey[200],
              child: const Center(child: Icon(Icons.broken_image_outlined)),
            ),
          );
        },
      ),
    );
  }

  Widget _buildInteractionBar(ColorScheme colorScheme) {
    final iconColor = isLiked ? colorScheme.primary : colorScheme.onSurfaceVariant;
    final likeIconColor = isLiked ? colorScheme.primary : null;

    return Row(
      mainAxisAlignment: MainAxisAlignment.spaceAround,
      children: [
        _buildActionButton(
          icon: isLiked ? Icons.favorite : Icons.favorite_border,
          label: _formatCount(likeCount),
          color: likeIconColor,
          onTap: onLike,
        ),
        _buildActionButton(
          icon: Icons.chat_bubble_outline,
          label: _formatCount(commentCount),
          color: iconColor,
          onTap: onComment,
        ),
        _buildActionButton(
          icon: Icons.share_outlined,
          label: _formatCount(shareCount),
          color: iconColor,
          onTap: onShare,
        ),
      ],
    );
  }

  Widget _buildActionButton({
    required IconData icon,
    required String label,
    Color? color,
    required VoidCallback onTap,
  }) {
    return Semantics(label: '$label', child: InkWell(
      borderRadius: BorderRadius.circular(20),
      onTap: onTap,
      child: Padding(
        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 4),
        child: Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            Icon(icon, size: 20, color: color),
            const SizedBox(width: 4),
            Text(label, style: TextStyle(fontSize: 13, color: color)),
          ],
        ),
      ),
    ));
  }

  String _formatCount(int count) {
    if (count >= 10000) return '${(count / 10000).toStringAsFixed(1)}w';
    if (count >= 1000) return '${(count / 1000).toStringAsFixed(1)}k';
    return count.toString();
  }
}

class TopicChip extends StatelessWidget {
  final String coverUrl;
  final String name;
  final int postCount;
  final VoidCallback onTap;

  const TopicChip({
    super.key,
    required this.coverUrl,
    required this.name,
    required this.postCount,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return Semantics(label: 'Topic: $name, $postCount posts', child: Card(
      clipBehavior: Clip.antiAlias,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
      child: InkWell(
        onTap: onTap,
        child: SizedBox(
          width: 140,
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              SizedBox(
                height: 90,
                width: double.infinity,
                child: Image.network(
                  coverUrl,
                  fit: BoxFit.cover,
                  semanticLabel: 'Cover for $name',
                  errorBuilder: (_, __, ___) => Container(
                    color: Colors.grey[300],
                    child: const Center(child: Icon(Icons.image_outlined, size: 32)),
                  ),
                ),
              ),
              Padding(
                padding: const EdgeInsets.all(10),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      name,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: TextStyle(
                        fontWeight: FontWeight.w600,
                        fontSize: 14,
                        color: colorScheme.onSurface,
                      ),
                    ),
                    const SizedBox(height: 4),
                    Text(
                      '$postCount 条内容',
                      style: TextStyle(
                        fontSize: 12,
                        color: colorScheme.onSurfaceVariant,
                      ),
                    ),
                  ],
                ),
              ),
            ],
          ),
        ),
      ),
    ));
  }
}
