class ApplicationStatusBadge extends StatelessWidget {
  final ApplicationStatus status;

  const ApplicationStatusBadge({
    super.key,
    required this.status,
  });

  @override
  Widget build(BuildContext context) {
    final (Color bgColor, Color textColor, String label) = status.displayData;

    return Semantics(
      label: 'Application status: $label',
      child: Container(
        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 6),
        decoration: BoxDecoration(
          color: bgColor.withOpacity(0.15),
          borderRadius: BorderRadius.circular(16),
          border: Border.all(color: bgColor.withOpacity(0.3)),
        ),
        child: Text(
          label,
          style: TextStyle(
            fontSize: 13,
            fontWeight: FontWeight.w600,
            color: textColor,
          ),
        ),
      ),
    );
  }
}

enum ApplicationStatus {
  submitted,
  viewed,
  communicating,
  interview,
  hired,
  rejected;

  (Color, Color, String) get displayData {
    switch (this) {
      case ApplicationStatus.submitted:
        return (Colors.blue, Colors.blue, '投递成功');
      case ApplicationStatus.viewed:
        return (Colors.orange, Colors.orange, '已查看');
      case ApplicationStatus.communicating:
        return (Colors.purple, Colors.purple, '沟通中');
      case ApplicationStatus.interview:
        return (Colors.teal, Colors.teal, '面试');
      case ApplicationStatus.hired:
        return (Colors.green, Colors.green, '录用');
      case ApplicationStatus.rejected:
        return (Colors.grey, Colors.grey, '不合适');
    }
  }
}
