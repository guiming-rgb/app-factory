import 'package:flutter/material.dart';
import '../../../core/theme/app_theme.dart';

/// A hero weather card with gradient background and current conditions.
class WeatherNowHero extends StatelessWidget {
  final String cityName;
  final String temperature;
  final IconData weatherIcon;
  final String condition;
  final String feelsLike;
  final String humidity;
  final String windSpeed;
  final String weatherType;

  const WeatherNowHero({
    super.key,
    required this.cityName,
    required this.temperature,
    required this.weatherIcon,
    required this.condition,
    required this.feelsLike,
    required this.humidity,
    required this.windSpeed,
    this.weatherType = 'default',
  });

  List<Color> _backgroundGradient() {
    switch (weatherType) {
      case 'rain':
        return [Colors.blue[800]!, Colors.blue[400]!];
      case 'snow':
        return [Colors.grey[600]!, Colors.grey[300]!];
      default:
        return [Colors.lightBlue[400]!, Colors.lightBlue[200]!];
    }
  }

  @override
  Widget build(BuildContext context) {
    final gradient = _backgroundGradient();
    return Container(
      width: double.infinity,
      padding: const EdgeInsets.all(20),
      decoration: BoxDecoration(
        gradient: LinearGradient(
          colors: gradient,
          begin: Alignment.topCenter,
          end: Alignment.bottomCenter,
        ),
        borderRadius: BorderRadius.circular(16),
      ),
      child: Column(
        children: [
          // City name
          Text(
            cityName,
            style: const TextStyle(
              color: Colors.white,
              fontSize: 18,
              fontWeight: FontWeight.w500,
            ),
          ),
          const SizedBox(height: 8),
          // Weather icon
          Icon(weatherIcon, size: 56, color: Colors.white),
          const SizedBox(height: 8),
          // Temperature
          Text(
            '$temperature°',
            style: const TextStyle(
              color: Colors.white,
              fontSize: 64,
              fontWeight: FontWeight.w100,
            ),
          ),
          const SizedBox(height: 4),
          // Condition text
          Text(
            condition,
            style: const TextStyle(
              color: Colors.white,
              fontSize: 16,
            ),
          ),
          const SizedBox(height: 16),
          // Stats row
          Row(
            mainAxisAlignment: MainAxisAlignment.spaceEvenly,
            children: [
              _buildStatItem('Feels like', feelsLike),
              _buildStatItem('Humidity', humidity),
              _buildStatItem('Wind', windSpeed),
            ],
          ),
        ],
      ),
    );
  }

  Widget _buildStatItem(String label, String value) {
    return Column(
      children: [
        Text(
          value,
          style: const TextStyle(
            color: Colors.white,
            fontSize: 14,
            fontWeight: FontWeight.w600,
          ),
        ),
        const SizedBox(height: 2),
        Text(
          label,
          style: const TextStyle(
            color: Colors.white70,
            fontSize: 11,
          ),
        ),
      ],
    );
  }
}

/// A horizontal hourly forecast row (100px tall).
class HourlyForecastRow extends StatelessWidget {
  final List<Map<String, dynamic>> hours;

  const HourlyForecastRow({
    super.key,
    required this.hours,
  });

  @override
  Widget build(BuildContext context) {
    return SizedBox(
      height: 100,
      child: ListView.separated(
        scrollDirection: Axis.horizontal,
        padding: const EdgeInsets.symmetric(horizontal: 16),
        itemCount: hours.length,
        separatorBuilder: (_, __) => const SizedBox(width: 12),
        itemBuilder: (context, index) {
          final hour = hours[index];
          return SizedBox(
            width: 48,
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Text(
                  hour['time'] as String,
                  style: TextStyle(
                    color: Colors.grey[600],
                    fontSize: 12,
                  ),
                ),
                const SizedBox(height: 4),
                Icon(
                  hour['icon'] as IconData,
                  size: 22,
                  color: Colors.amber[600],
                ),
                const SizedBox(height: 4),
                Text(
                  '${hour['temp']}°',
                  style: const TextStyle(
                    fontSize: 14,
                    fontWeight: FontWeight.w600,
                  ),
                ),
              ],
            ),
          );
        },
      ),
    );
  }
}

/// A single daily forecast item with temperature bar.
class DailyForecastItem extends StatelessWidget {
  final String date;
  final IconData icon;
  final int lowTemp;
  final int highTemp;
  final int currentTemp;

  const DailyForecastItem({
    super.key,
    required this.date,
    required this.icon,
    required this.lowTemp,
    required this.highTemp,
    required this.currentTemp,
  });

  @override
  Widget build(BuildContext context) {
    final double fraction =
        (currentTemp - lowTemp) / ((highTemp - lowTemp).clamp(1, 100));
    return Row(
      children: [
        // Date
        SizedBox(
          width: 60,
          child: Text(
            date,
            style: const TextStyle(fontSize: 14),
          ),
        ),
        const SizedBox(width: 8),
        // Icon
        Icon(icon, size: 20, color: Colors.amber[600]),
        const SizedBox(width: 12),
        // Low temp
        SizedBox(
          width: 28,
          child: Text(
            '$lowTemp°',
            textAlign: TextAlign.right,
            style: TextStyle(
              color: Colors.grey[600],
              fontSize: 13,
            ),
          ),
        ),
        const SizedBox(width: 8),
        // Gradient temperature bar with positioned dot
        Expanded(
          child: LayoutBuilder(
            builder: (context, constraints) {
              final double barWidth = constraints.maxWidth;
              final double dotLeft = fraction * barWidth;
              return Stack(
                alignment: Alignment.centerLeft,
                children: [
                  Container(
                    height: 4,
                    decoration: BoxDecoration(
                      gradient: LinearGradient(
                        colors: [
                          Colors.lightBlue[300]!,
                          Colors.orange[300]!,
                        ],
                      ),
                      borderRadius: BorderRadius.circular(2),
                    ),
                  ),
                  Positioned(
                    left: (dotLeft - 4).clamp(0.0, barWidth - 8),
                    child: Container(
                      width: 8,
                      height: 8,
                      decoration: const BoxDecoration(
                        color: Colors.white,
                        shape: BoxShape.circle,
                        boxShadow: [
                          BoxShadow(
                            color: Colors.black26,
                            blurRadius: 2,
                          ),
                        ],
                      ),
                    ),
                  ),
                ],
              );
            },
          ),
        ),
        const SizedBox(width: 8),
        // High temp
        SizedBox(
          width: 28,
          child: Text(
            '$highTemp°',
            style: const TextStyle(
              fontSize: 13,
              fontWeight: FontWeight.w600,
            ),
          ),
        ),
      ],
    );
  }
}

/// A circular AQI gauge that colors by air quality range.
class AqiGauge extends StatelessWidget {
  final int value;
  final String level;
  final String description;

  const AqiGauge({
    super.key,
    required this.value,
    required this.level,
    required this.description,
  });

  Color _aqiColor() {
    if (value <= 50) return Colors.green;
    if (value <= 100) return Colors.yellow[700]!;
    if (value <= 150) return Colors.orange;
    if (value <= 200) return Colors.red;
    return Colors.purple;
  }

  @override
  Widget build(BuildContext context) {
    final Color color = _aqiColor();
    return Column(
      mainAxisSize: MainAxisSize.min,
      children: [
        SizedBox(
          width: 100,
          height: 100,
          child: Stack(
            alignment: Alignment.center,
            children: [
              SizedBox(
                width: 100,
                height: 100,
                child: CircularProgressIndicator(
                  value: value / 300.0,
                  strokeWidth: 8,
                  backgroundColor: Colors.grey[200],
                  valueColor: AlwaysStoppedAnimation<Color>(color),
                ),
              ),
              Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  Text(
                    '$value',
                    style: TextStyle(
                      fontSize: 24,
                      fontWeight: FontWeight.bold,
                      color: color,
                    ),
                  ),
                  Text(
                    level,
                    style: TextStyle(
                      fontSize: 11,
                      color: color,
                    ),
                  ),
                ],
              ),
            ],
          ),
        ),
        const SizedBox(height: 8),
        Text(
          description,
          style: TextStyle(
            color: Colors.grey[600],
            fontSize: 13,
          ),
          textAlign: TextAlign.center,
        ),
      ],
    );
  }
}

