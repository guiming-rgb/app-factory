import 'package:flutter/material.dart';
import '../../../core/theme/app_theme.dart';

/// {{industry}} game widgets for {{displayName}} app.
/// Uses {{primaryColor}} as the accent color.

class GameTile extends StatelessWidget {
  final String coverUrl;
  final String name;
  final String genre;
  final double rating;
  final int playerCount;
  final VoidCallback onTap;

  const GameTile({
    super.key,
    required this.coverUrl,
    required this.name,
    required this.genre,
    this.rating = 0,
    this.playerCount = 0,
    required this.onTap,
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return SizedBox(
      width: 140,
      child: Card(
        margin: EdgeInsets.zero,
        clipBehavior: Clip.antiAlias,
        child: InkWell(
          onTap: onTap,
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              _buildCover(colorScheme),
              Padding(
                padding: const EdgeInsets.fromLTRB(10, 10, 10, 8),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Text(
                      name,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: const TextStyle(
                        fontWeight: FontWeight.bold,
                        fontSize: 13,
                      ),
                    ),
                    const SizedBox(height: 4),
                    Text(
                      genre,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: TextStyle(
                        fontSize: 11,
                        color: colorScheme.onSurfaceVariant,
                      ),
                    ),
                    const SizedBox(height: 6),
                    Row(
                      children: [
                        ...List.generate(
                          rating.round() > 5 ? 5 : rating.round(),
                          (_) => const Icon(Icons.star, size: 12, color: Colors.amber),
                        ),
                        const SizedBox(width: 4),
                        Expanded(
                          child: Text(
                            '${_formatCount(playerCount)}人',
                            maxLines: 1,
                            overflow: TextOverflow.ellipsis,
                            style: TextStyle(
                              fontSize: 10,
                              color: colorScheme.onSurfaceVariant,
                            ),
                          ),
                        ),
                      ],
                    ),
                  ],
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _buildCover(ColorScheme colorScheme) {
    return AspectRatio(
      aspectRatio: 1 / 1,
      child: coverUrl.isNotEmpty
          ? Image.network(
              coverUrl,
              fit: BoxFit.cover,
              errorBuilder: (_, __, ___) => _coverFallback(colorScheme),
              loadingBuilder: (_, child, progress) {
                if (progress == null) return child;
                return _coverFallback(colorScheme);
              },
            )
          : _coverFallback(colorScheme),
    );
  }

  Widget _coverFallback(ColorScheme colorScheme) {
    return Container(
      color: colorScheme.primaryContainer.withValues(alpha: 0.5),
      child: Icon(Icons.sports_esports, size: 48, color: colorScheme.onPrimaryContainer),
    );
  }

  String _formatCount(int count) {
    if (count >= 10000) return '${(count / 10000).toStringAsFixed(1)}w';
    if (count >= 1000) return '${(count / 1000).toStringAsFixed(1)}k';
    return count.toString();
  }
}

class LeaderboardEntry extends StatelessWidget {
  final int rank;
  final String avatarUrl;
  final String name;
  final int score;
  final bool isCurrentUser;

  const LeaderboardEntry({
    super.key,
    required this.rank,
    required this.avatarUrl,
    required this.name,
    required this.score,
    this.isCurrentUser = false,
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 3),
      decoration: BoxDecoration(
        color: isCurrentUser
            ? colorScheme.primary.withValues(alpha: 0.08)
            : Colors.transparent,
        borderRadius: BorderRadius.circular(10),
      ),
      child: ListTile(
        leading: _buildRankBadge(colorScheme),
        leadingAndTrailingTextStyle: const TextStyle(fontSize: 14),
        title: Row(
          children: [
            CircleAvatar(
              radius: 18,
              backgroundImage: avatarUrl.isNotEmpty
                  ? NetworkImage(avatarUrl)
                  : null,
              child: avatarUrl.isEmpty
                  ? Icon(Icons.person, size: 18, color: colorScheme.onSurfaceVariant)
                  : null,
            ),
            const SizedBox(width: 10),
            Text(
              name,
              maxLines: 1,
              overflow: TextOverflow.ellipsis,
              style: TextStyle(
                fontWeight: isCurrentUser ? FontWeight.w600 : FontWeight.normal,
                fontSize: 14,
              ),
            ),
          ],
        ),
        trailing: Text(
          score.toString(),
          style: TextStyle(
            fontWeight: FontWeight.bold,
            fontSize: 16,
            color: colorScheme.primary,
          ),
        ),
      ),
    );
  }

  Widget _buildRankBadge(ColorScheme colorScheme) {
    if (rank == 1) {
      return const Text('🥇', style: TextStyle(fontSize: 24));
    }
    if (rank == 2) {
      return const Text('🥈', style: TextStyle(fontSize: 24));
    }
    if (rank == 3) {
      return const Text('🥉', style: TextStyle(fontSize: 24));
    }
    return SizedBox(
      width: 36,
      child: Center(
        child: Text(
          '$rank',
          style: TextStyle(
            fontSize: 15,
            fontWeight: FontWeight.w600,
            color: colorScheme.onSurfaceVariant,
          ),
        ),
      ),
    );
  }
}

class AchievementCard extends StatelessWidget {
  final IconData icon;
  final String name;
  final String description;
  final int currentProgress;
  final int totalProgress;
  final bool isUnlocked;

  const AchievementCard({
    super.key,
    required this.icon,
    required this.name,
    required this.description,
    this.currentProgress = 0,
    this.totalProgress = 0,
    this.isUnlocked = false,
  });

  @override
  Widget build(BuildContext context) {
    final colorScheme = Theme.of(context).colorScheme;

    return Opacity(
      opacity: isUnlocked ? 1.0 : 0.5,
      child: Card(
        margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 4),
        child: Padding(
          padding: const EdgeInsets.all(14),
          child: Row(
            children: [
              Icon(
                icon,
                size: 32,
                color: isUnlocked ? Colors.amber : Colors.grey[400],
              ),
              const SizedBox(width: 14),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    Row(
                      children: [
                        Expanded(
                          child: Text(
                            name,
                            maxLines: 1,
                            overflow: TextOverflow.ellipsis,
                            style: const TextStyle(
                              fontWeight: FontWeight.bold,
                              fontSize: 13,
                            ),
                          ),
                        ),
                        if (isUnlocked)
                          Icon(
                            Icons.check_circle,
                            size: 18,
                            color: colorScheme.primary,
                          ),
                      ],
                    ),
                    const SizedBox(height: 4),
                    Text(
                      description,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: TextStyle(
                        fontSize: 11,
                        color: colorScheme.onSurfaceVariant,
                      ),
                    ),
                    if (totalProgress > 0) ...[
                      const SizedBox(height: 8),
                      Row(
                        children: [
                          Expanded(
                            child: ClipRRect(
                              borderRadius: BorderRadius.circular(4),
                              child: LinearProgressIndicator(
                                value: currentProgress / totalProgress,
                                backgroundColor: colorScheme.surfaceContainerHighest,
                                color: isUnlocked
                                    ? colorScheme.primary
                                    : Colors.grey[400],
                                minHeight: 6,
                              ),
                            ),
                          ),
                          const SizedBox(width: 8),
                          Text(
                            '$currentProgress / $totalProgress',
                            style: TextStyle(
                              fontSize: 11,
                              color: colorScheme.onSurfaceVariant,
                            ),
                          ),
                        ],
                      ),
                    ],
                  ],
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
