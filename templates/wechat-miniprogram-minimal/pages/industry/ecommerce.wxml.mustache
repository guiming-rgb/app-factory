<!-- {{displayName}} — E-commerce Product List (Mustache template) -->
<!-- Variables: displayName, primaryColor, tableName -->

<view class="page" style="--primary: {{primaryColor}};">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索商品" bindinput="onSearchInput" />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <view class="filter-bar">
    <view class="filter-item active">综合</view>
    <view class="filter-item" bindtap="onSortBySales">销量</view>
    <view class="filter-item" bindtap="onSortByPrice">价格</view>
    <view class="filter-item" bindtap="onFilterCategory">分类</view>
  </view>

  <scroll-view class="product-list" scroll-y bindscrolltolower="onLoadMore">
    <view wx:for="{{products}}" wx:key="id" class="product-card" bindtap="onProductTap" data-id="{{item.id}}">
      <image class="product-image" src="{{item.imageUrl || 'https://via.placeholder.com/200'}}" mode="aspectFill" />
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-meta">
          <text class="product-price">¥{{item.price}}</text>
          <text class="product-sales" wx:if="{{item.sales}}">已售 {{item.sales}}</text>
        </view>
        <view class="product-rating" wx:if="{{item.rating}}">
          <text class="rating-stars">{{item.rating}}分</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>
