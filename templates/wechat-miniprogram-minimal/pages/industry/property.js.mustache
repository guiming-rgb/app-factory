// {{displayName}} — Smart Property Dashboard Page (Mustache template)
// Variables: displayName, primaryColor, tableName

const app = getApp();
const { propertyService } = require("../../services/industry");

Page({
  data: {
    repairs: [],
    bills: [],
    pendingRepairs: 0,
    unpaidBills: 0,
    unreadNotices: 0,
    parkingAvailable: 0,
    statusLabels: {
      pending: '待处理', processing: '处理中', completed: '已完成', cancelled: '已取消',
    },
    billTypeLabels: {
      property: '物业费', water: '水费', electricity: '电费', gas: '燃气费', other: '其他',
    },
    loading: false,
    refreshing: false,
    error: false,
  },

  onLoad() {
    this.loadData();
  },

  onShow() {
    this.loadData();
  },

  async loadData() {
    this.setData({ loading: true, error: false });

    try {
      await Promise.all([
        this.loadRepairs(),
        this.loadBills(),
        this.loadNotices(),
        this.loadParking(),
      ]);

      this.setData({ loading: false, refreshing: false });
    } catch (e) {
      console.error('loadData error:', e);
      this.setData({ loading: false, refreshing: false, error: true });
    }
  },

  async loadRepairs() {
    const res = await propertyService.getRepairs({ limit: 5, orderBy: 'created_at', orderDir: 'desc' });
    const list = (res.data || []).map(item => ({
      id: item.id,
      title: item.title || item.description || '',
      room: item.room || item.location || '',
      status: item.status || 'pending',
      worker: item.worker || '',
      createdAt: item.created_at ? item.created_at.slice(0, 16).replace('T', ' ') : '',
    }));

    const pending = list.filter(r => r.status === 'pending' || r.status === 'processing').length;

    this.setData({
      repairs: list,
      pendingRepairs: pending,
    });
  },

  async loadBills() {
    const res = await propertyService.getBills({ limit: 5, orderBy: 'due_date', orderDir: 'asc' });
    const list = (res.data || []).map(item => ({
      id: item.id,
      type: item.type || 'property',
      amount: item.amount || 0,
      period: item.period || item.bill_period || '',
      status: item.status || 'unpaid',
      dueDate: item.due_date || '',
    }));

    const unpaid = list.filter(b => b.status === 'unpaid').length;

    this.setData({
      bills: list,
      unpaidBills: unpaid,
    });
  },

  async loadNotices() {
    try {
      const res = await propertyService.getNotices({ limit: 1, unread: true });
      const unread = res.count || (res.data || []).length;
      this.setData({ unreadNotices: unread });
    } catch (e) {
      console.error('loadNotices error:', e);
    }
  },

  async loadParking() {
    try {
      const res = await propertyService.getParkingAvailable();
      const count = res.count || (res.data || []).length || 0;
      this.setData({ parkingAvailable: count });
    } catch (e) {
      console.error('loadParking error:', e);
    }
  },

  onPullRefresh() {
    this.setData({ refreshing: true });
    this.loadData();
  },

  onRepairTap(e) {
    const id = e.currentTarget.dataset.id;
    wx.navigateTo({ url: `/pages/repair_detail/repair_detail?id=${id}` });
  },

  onBillTap(e) {
    const id = e.currentTarget.dataset.id;
    wx.navigateTo({ url: `/pages/bill_detail/bill_detail?id=${id}` });
  },

  onNavigateRepair() {
    wx.navigateTo({ url: '/pages/repair_list/repair_list' });
  },

  onNavigatePayment() {
    wx.navigateTo({ url: '/pages/bill_list/bill_list' });
  },

  onNavigateNotice() {
    wx.navigateTo({ url: '/pages/notice_list/notice_list' });
  },

  onNavigateParking() {
    wx.navigateTo({ url: '/pages/parking/parking' });
  },

  onViewAllRepairs() {
    wx.navigateTo({ url: '/pages/repair_list/repair_list' });
  },

  onViewAllBills() {
    wx.navigateTo({ url: '/pages/bill_list/bill_list' });
  },
});
