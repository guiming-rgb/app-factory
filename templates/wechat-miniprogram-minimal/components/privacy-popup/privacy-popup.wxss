.mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog {
  width: 80%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.body {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.btn {
  background-color: #0d9488 !important;
}
