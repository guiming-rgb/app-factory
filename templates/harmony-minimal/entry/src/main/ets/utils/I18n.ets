  };

  static init(context: Context): void {
    try {
      const systemLocale = i18n.System.getSystemLanguage();
      let locale = systemLocale.split('-')[0];
      if (systemLocale.startsWith('zh-Hans')) {
        locale = 'zh';
      } else if (systemLocale.startsWith('zh-Hant')) {
        locale = 'zh_TW';
      }
      if (!I18n.locales[locale]) {
        locale = 'en';
      }
      if (!I18n.instance) {
        I18n.instance = new I18n();
      }
      I18n.instance.currentLocale = locale;
      I18n.saveLocaleToStorage(locale);
    } catch {
      if (!I18n.instance) {
        I18n.instance = new I18n();
      }
      I18n.instance.currentLocale = 'en';
    }
  }

  static t(key: string, params?: Record<string, string>): string {
    if (!I18n.instance) {
      I18n.instance = new I18n();
    }
    const locale = I18n.instance.currentLocale;
    const parts = key.split('.');
    let result: Record<string, Object> = I18n.locales[locale];
    if (!result) {
      result = I18n.locales['en'];
    }
    for (let i = 0; i < parts.length; i++) {
      if (result && typeof result === 'object' && parts[i] in result) {
        result = result[parts[i]] as Record<string, Object>;
      } else {
        // Fallback to English
        let fallback: Record<string, Object> = I18n.locales['en'];
        for (let j = 0; j < parts.length; j++) {
          if (fallback && typeof fallback === 'object' && parts[j] in fallback) {
            fallback = fallback[parts[j]] as Record<string, Object>;
          } else {
            return key;
          }
        }
        if (typeof fallback === 'string') {
          return I18n.interpolate(fallback as string, params);
        }
        return key;
      }
    }
    if (typeof result === 'string') {
      return I18n.interpolate(result, params);
    }
    return key;
  }

  private static interpolate(template: string, params?: Record<string, string>): string {
    if (!params) {
      return template;
    }
    let result = template;
    const keys = Object.keys(params);
    for (let i = 0; i < keys.length; i++) {
      const k = keys[i];
      result = result.split('{{' + k + '}}').join(params[k]);
    }
    return result;
  }

  static setLocale(locale: string): void {
    if (!I18n.locales[locale]) {
      return;
    }
    if (!I18n.instance) {
      I18n.instance = new I18n();
    }
    I18n.instance.currentLocale = locale;
    I18n.saveLocaleToStorage(locale);
  }

  static getLocale(): string {
    if (!I18n.instance) {
      I18n.instance = new I18n();
    }
    return I18n.instance.currentLocale;
  }

  static has(key: string): boolean {
    const locale = I18n.getLocale();
    const parts = key.split('.');
    let result: Record<string, Object> = I18n.locales[locale];
    if (!result) {
      return false;
    }
    for (let i = 0; i < parts.length; i++) {
      if (result && typeof result === 'object' && parts[i] in result) {
        result = result[parts[i]] as Record<string, Object>;
      } else {
        return false;
      }
    }
    return typeof result === 'string';
  }

  private static saveLocaleToStorage(locale: string): void {
    try {
      AppStorage.set<string>('app_language', locale);
    } catch {
      // AppStorage not available in all contexts
    }
  }
}