// {{displayName}} — Photo Gallery (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct PhotoCard {
  @State imageUrl: string = ''
  @State likes: number = 0
  @State comments: number = 0
  @State tags: string[] = []
  photoId: string = ''

  build() {
    Column() {
      Stack() {
        Image(this.imageUrl || 'https://via.placeholder.com/300')
          .width('100%').height(180).objectFit(ImageFit.Cover)
          .borderRadius(10)
        Column() {
          Row() {
            Text(`${this.likes}`).fontSize(11).fontColor(Color.White)
            Text('♥').fontSize(12).fontColor('#ff4081').margin({ left: 4 })
          }
          Row() {
            Text(`${this.comments}`).fontSize(11).fontColor(Color.White)
            Text('💬').fontSize(12).margin({ left: 4 })
          }.margin({ top: 4 })
        }
        .position({ bottom: 8, right: 8 })
        .padding({ left: 8, right: 8, top: 4, bottom: 4 })
        .backgroundColor('#66000000')
        .borderRadius(8)
      }.width('100%')
      if (this.tags.length > 0) {
        Scroll() {
          Row() {
            ForEach(this.tags, (tag: string) => {
              Text(`# ${tag}`)
                .fontSize(10).fontColor('{{primaryColor}}')
                .backgroundColor('{{primaryColor}}1a')
                .borderRadius(8).padding({ left: 6, right: 6, top: 2, bottom: 2 })
                .margin({ right: 4 })
            })
          }
        }.scrollable(ScrollDirection.Horizontal).height(28).margin({ top: 6 })
      }
    }
    .borderRadius(10).backgroundColor(Color.White)
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/PhotoDetail', params: { id: this.photoId } })
    })
  }
}

@Entry
@Component
struct PhotoPage {
  @State photos: Array<{
    id: string, imageUrl: string, likes: number,
    comments: number, tags: string[]
  }> = []
  @State tagSearch: string = ''
  @State loading: boolean = false
  private searchController: TextInputController = new TextInputController()

  aboutToAppear() {
    this.loadPhotos()
  }

  async loadPhotos() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").limit(30).order("likes", { ascending: false })
    this.photos = [
      { id: '1', imageUrl: '', likes: 256, comments: 18, tags: ['自然', '风景'] },
      { id: '2', imageUrl: '', likes: 189, comments: 12, tags: ['城市', '建筑'] },
      { id: '3', imageUrl: '', likes: 342, comments: 24, tags: ['美食', '摄影'] },
      { id: '4', imageUrl: '', likes: 98, comments: 5, tags: ['人像'] },
      { id: '5', imageUrl: '', likes: 512, comments: 36, tags: ['旅行', '自然'] },
      { id: '6', imageUrl: '', likes: 156, comments: 9, tags: ['黑白', '艺术'] },
    ]
    this.loading = false
  }

  build() {
    Column() {
      // Header
      Text('{{displayName}}').fontSize(20).fontWeight(FontWeight.Bold)
        .width('100%').padding(16)

      // Search by tag
      TextInput({ placeholder: '搜索标签...', controller: this.searchController })
        .height(40).backgroundColor('#f5f5f5').borderRadius(20)
        .padding({ left: 16, right: 16 }).margin({ left: 16, right: 16, bottom: 8 })
        .onChange((v: string) => { this.tagSearch = v })

      // Challenge banner
      Row() {
        Column() {
          Text('📷 今日挑战').fontSize(16).fontWeight(FontWeight.Bold).fontColor(Color.White)
          Text('日落主题 · 参与即可获得徽章').fontSize(12).fontColor('#ffffffb3').margin({ top: 4 })
        }.alignItems(HorizontalAlign.Start).layoutWeight(1)
        Text('参与 >').fontSize(14).fontColor(Color.White).fontWeight(FontWeight.Medium)
      }
      .width('100%').padding(16)
      .backgroundColor('{{primaryColor}}').borderRadius(12)
      .margin({ left: 16, right: 16, bottom: 12 })
      .onClick(() => { router.pushUrl({ url: 'pages/PhotoChallenge', params: {} }) })

      // Photo grid
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 40 })
      } else if (this.photos.length === 0) {
        Column() {
          Text('暂无照片').fontSize(16).fontColor('#999')
        }.width('100%').margin({ top: 40 })
      } else {
        Scroll() {
          Column() {
            Grid() {
              ForEach(this.photos, (item: {
                id: string, imageUrl: string, likes: number,
                comments: number, tags: string[]
              }, index?: number) => {
                GridItem() {
                  PhotoCard({
                    imageUrl: item.imageUrl,
                    likes: item.likes, comments: item.comments,
                    tags: item.tags, photoId: item.id
                  })
                }
              })
            }
            .columnsTemplate('1fr 1fr')
            .rowsTemplate('auto')
            .columnsGap(10).rowsGap(10)
            .padding({ left: 16, right: 16, bottom: 24 })
          }
        }.layoutWeight(1)
      }
    }
    .width('100%')
    .height('100%')
  }
}
