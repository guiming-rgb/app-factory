// {{displayName}} — E-commerce Product List Page (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct ProductCard {
  @State name: string = '';
  @State price: number = 0;
  @State imageUrl: string = '';
  @State rating: number = 0;
  @State sales: number = 0;
  productId: string = '';

  build() {
    Column() {
      Image(this.imageUrl || 'https://via.placeholder.com/200')
        .width('100%')
        .height(180)
        .objectFit(ImageFit.Cover)
        .borderRadius({ topLeft: 12, topRight: 12 })
      Column() {
        Text(this.name)
          .fontSize(16)
          .fontWeight(FontWeight.Medium)
          .lineHeight(22)
          .maxLines(2)
          .textOverflow({ overflow: TextOverflow.Ellipsis })
          .width('100%')
        Row() {
          Text(`¥${this.price}`)
            .fontSize(18)
            .fontWeight(FontWeight.Bold)
            .fontColor('{{primaryColor}}')
          Blank()
          Text(`${this.rating}分`)
            .fontSize(12)
            .fontColor('#FF9500')
          Text(`已售${this.sales}`)
            .fontSize(11)
            .fontColor('#999')
            .margin({ left: 8 })
        }.width('100%').margin({ top: 8 })
      }.padding(12)
    }
    .width('48%')
    .backgroundColor(Color.White)
    .borderRadius(12)
    .shadow({ radius: 4, color: '#1a000000', offsetX: 0, offsetY: 2 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/ProductDetail', params: { id: this.productId } })
    })
  }
}

@Entry
@Component
struct ECommercePage {
  @State products: Array<{
    id: string, name: string, price: number,
    imageUrl: string, rating: number, sales: number
  }> = []
  @State loading: boolean = false
  @State keyword: string = ''
  private searchController: TextInputController = new TextInputController()

  aboutToAppear() {
    this.loadProducts()
  }

  async loadProducts() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").limit(20)
    // this.products = data || []
    this.products = [
      { id: '1', name: '示例商品 1', price: 99.00, imageUrl: '', rating: 4.5, sales: 128 },
      { id: '2', name: '示例商品 2', price: 199.00, imageUrl: '', rating: 4.8, sales: 256 },
    ]
    this.loading = false
  }

  build() {
    Column() {
      // Search bar
      Row() {
        TextInput({ placeholder: '搜索商品', controller: this.searchController })
          .layoutWeight(1)
          .height(40)
          .backgroundColor('#f5f5f5')
          .borderRadius(20)
          .padding({ left: 16, right: 16 })
          .onChange((v: string) => { this.keyword = v })
        Button('搜索')
          .backgroundColor('{{primaryColor}}')
          .fontColor(Color.White)
          .borderRadius(20)
          .margin({ left: 8 })
          .onClick(() => this.loadProducts())
      }.padding(16)

      // Grid
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 60 })
      } else {
        Grid() {
          ForEach(this.products, (item: {
            id: string, name: string, price: number,
            imageUrl: string, rating: number, sales: number
          }, index?: number) => {
            GridItem() {
              ProductCard({
                name: item.name, price: item.price,
                imageUrl: item.imageUrl, rating: item.rating,
                sales: item.sales, productId: item.id
              })
            }
          })
        }
        .columnsTemplate('1fr 1fr')
        .rowsTemplate('auto')
        .columnsGap(12)
        .rowsGap(12)
        .padding(16)
      }
    }
    .width('100%')
    .height('100%')
  }
}
