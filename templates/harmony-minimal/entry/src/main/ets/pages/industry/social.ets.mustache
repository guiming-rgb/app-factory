// {{displayName}} — Social Feed (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct PostCard {
  @State authorName: string = ''
  @State authorAvatar: string = ''
  @State content: string = ''
  @State images: string[] = []
  @State likes: number = 0
  @State liked: boolean = false
  @State comments: number = 0
  postId: string = ''

  build() {
    Column() {
      // Author row
      Row() {
        Image(this.authorAvatar || 'https://via.placeholder.com/40')
          .width(40).height(40).borderRadius(20).objectFit(ImageFit.Cover)
        Column() {
          Text(this.authorName).fontSize(15).fontWeight(FontWeight.Medium)
        }.alignItems(HorizontalAlign.Start).margin({ left: 10 }).layoutWeight(1)
        Text('· · ·').fontSize(16).fontColor('#ccc')
      }.width('100%')

      // Content
      Text(this.content).fontSize(14).lineHeight(20).margin({ top: 10 })
        .width('100%')

      // Images grid
      if (this.images.length > 0) {
        Grid() {
          ForEach(this.images, (img: string, index?: number) => {
            GridItem() {
              Image(img || 'https://via.placeholder.com/160')
                .width('100%').aspectRatio(1).objectFit(ImageFit.Cover).borderRadius(8)
            }
          })
        }
        .columnsTemplate(this.images.length === 1 ? '1fr' : '1fr 1fr')
        .rowsTemplate('auto')
        .columnsGap(6).rowsGap(6)
        .margin({ top: 10 })
      }

      // Actions
      Row() {
        Row() {
          Text(this.liked ? '❤️' : '🤍').fontSize(18)
            .onClick(() => {
              this.liked = !this.liked
              this.likes += this.liked ? 1 : -1
            })
          Text(`${this.likes}`).fontSize(13).fontColor('#666').margin({ left: 4 })
        }
        .margin({ right: 24 })
        .onClick(() => {
          this.liked = !this.liked
          this.likes += this.liked ? 1 : -1
        })

        Row() {
          Text('💬').fontSize(16)
          Text(`${this.comments}`).fontSize(13).fontColor('#666').margin({ left: 4 })
        }
        .onClick(() => {
          router.pushUrl({ url: 'pages/PostComments', params: { id: this.postId } })
        })

        Blank()
        Text('↗').fontSize(18).fontColor('#999')
      }.width('100%').margin({ top: 12 })
    }
    .width('100%').padding(16).backgroundColor(Color.White).borderRadius(12)
    .margin({ bottom: 10 })
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
  }
}

@Entry
@Component
struct SocialPage {
  @State posts: Array<{
    id: string, authorName: string, authorAvatar: string,
    content: string, images: string[],
    likes: number, liked: boolean, comments: number
  }> = []
  @State topics: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '推荐', active: true },
    { id: 'tech', name: '科技', active: false },
    { id: 'life', name: '生活', active: false },
    { id: 'art', name: '艺术', active: false },
    { id: 'music', name: '音乐', active: false },
    { id: 'food', name: '美食', active: false },
  ]
  @State activeTopic: string = 'all'
  @State loading: boolean = false

  aboutToAppear() {
    this.loadPosts()
  }

  async loadPosts() {
    this.loading = true
    try {
      const result = await socialService.list();
      if (result && result.length > 0) {
        this.posts = result;
      }
    } catch (e) {
      // 加载失败
    } finally {
      this.loading = false;
    }
  }

  build() {
    Column() {
      // Header
      Row() {
        Text('{{displayName}}').fontSize(20).fontWeight(FontWeight.Bold).layoutWeight(1)
        Text('🔔').fontSize(20).margin({ right: 16 })
          .onClick(() => { router.pushUrl({ url: 'pages/Notifications' }) })
        Text('💬').fontSize(18)
          .onClick(() => { router.pushUrl({ url: 'pages/Messages' }) })
      }
      .padding({ left: 16, right: 16, top: 12, bottom: 8 })
      .width('100%')

      // Topic chips
      Scroll() {
        Row() {
          ForEach(this.topics, (topic: { id: string, name: string, active: boolean }) => {
            Text(topic.name)
              .fontSize(14)
              .fontColor(topic.active ? Color.White : '#333')
              .backgroundColor(topic.active ? '{{primaryColor}}' : '#f0f0f0')
              .borderRadius(16)
              .padding({ left: 16, right: 16, top: 6, bottom: 6 })
              .margin({ right: 8 })
              .onClick(() => {
                this.activeTopic = topic.id
                this.topics = this.topics.map(t => ({
                  ...t, active: t.id === topic.id
                }))
              })
          })
        }.padding({ left: 16, right: 16 })
      }.height(44).scrollable(ScrollDirection.Horizontal)

      // Feed
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 60 })
      } else if (this.posts.length === 0) {
        Column() {
          Text('暂无动态').fontSize(16).fontColor('#999')
          Text('关注更多用户发现精彩内容').fontSize(13).fontColor('#bbb').margin({ top: 6 })
        }.width('100%').margin({ top: 60 })
      } else {
        List() {
          ForEach(this.posts, (item: {
            id: string, authorName: string, authorAvatar: string,
            content: string, images: string[],
            likes: number, liked: boolean, comments: number
          }) => {
            ListItem() {
              PostCard({ ...item, postId: item.id })
            }
          })
        }
        .layoutWeight(1)
        .padding({ left: 16, right: 16, top: 8, bottom: 80 })
      }

      // FAB (create post)
      Column() {
        Text('✏️').fontSize(24)
      }
      .width(56).height(56).backgroundColor('{{primaryColor}}').borderRadius(28)
      .shadow({ radius: 6, color: '#33000000', offsetX: 0, offsetY: 3 })
      .alignItems(HorizontalAlign.Center).justifyContent(FlexAlign.Center)
      .position({ bottom: 24, right: 24 })
      .onClick(() => {
        router.pushUrl({ url: 'pages/CreatePost' })
      })
    }
    .width('100%')
    .height('100%')
  }
}
