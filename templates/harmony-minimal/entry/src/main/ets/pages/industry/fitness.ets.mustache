// {{displayName}} — Fitness / Workout (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct WorkoutCard {
  @State name: string = ''
  @State imageUrl: string = ''
  @State calories: number = 0
  @State duration: string = ''
  @State level: string = ''

  levelBgColor(): string {
    const colors: Record<string, string> = {
      '初级': '#e8f5e9', '中级': '#fff3e0', '高级': '#ffebee',
    }
    return colors[this.level] || '#f5f5f5'
  }

  levelTextColor(): string {
    const colors: Record<string, string> = {
      '初级': '#2e7d32', '中级': '#e65100', '高级': '#c62828',
    }
    return colors[this.level] || '#999'
  }

  build() {
    Column() {
      Stack() {
        Image(this.imageUrl || 'https://via.placeholder.com/200')
          .width('100%').height(140).objectFit(ImageFit.Cover)
          .borderRadius({ topLeft: 12, topRight: 12 })
        Text(this.level)
          .fontSize(11).fontColor(this.levelTextColor())
          .backgroundColor(this.levelBgColor())
          .borderRadius(8).padding({ left: 8, right: 8, top: 3, bottom: 3 })
          .position({ top: 8, right: 8 })
      }
      .width('100%')

      Column() {
        Text(this.name).fontSize(15).fontWeight(FontWeight.Medium)
          .maxLines(1).textOverflow({ overflow: TextOverflow.Ellipsis }).width('100%')
        Row() {
          Text(`🔥 ${this.calories}kcal`).fontSize(12).fontColor('#ff6d00')
          Blank()
          Text(`⏱ ${this.duration}`).fontSize(12).fontColor('#666')
        }.width('100%').margin({ top: 6 })
      }
      .padding(10).alignItems(HorizontalAlign.Start).width('100%')
    }
    .width('100%').backgroundColor(Color.White).borderRadius(12)
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/WorkoutDetail', params: { id: this.name } })
    })
  }
}

@Component
export struct StatCard {
  @State label: string = ''
  @State value: string = ''
  @State unit: string = ''
  @State icon: string = ''

  build() {
    Column() {
      Text(this.icon).fontSize(24)
      Text(this.value).fontSize(22).fontWeight(FontWeight.Bold)
        .fontColor('{{primaryColor}}').margin({ top: 6 })
      Row() {
        Text(this.label).fontSize(12).fontColor('#999')
        if (this.unit.length > 0) {
          Text(this.unit).fontSize(11).fontColor('#bbb').margin({ left: 2 })
        }
      }.margin({ top: 2 })
    }
    .width('100%').padding(14)
    .backgroundColor(Color.White).borderRadius(12)
  }
}

@Entry
@Component
struct FitnessPage {
  @State workouts: Array<{
    name: string, imageUrl: string,
    calories: number, duration: string, level: string
  }> = []
  @State categories: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '全部', active: true },
    { id: 'cardio', name: '有氧', active: false },
    { id: 'strength', name: '力量', active: false },
    { id: 'yoga', name: '瑜伽', active: false },
    { id: 'hiit', name: 'HIIT', active: false },
  ]
  @State activeCategory: string = 'all'
  @State dailyCalories: number = 450
  @State dailyGoal: number = 600
  @State weeklyWorkouts: number = 4
  @State totalMinutes: number = 280
  @State loading: boolean = false

  aboutToAppear() {
    this.loadData()
  }

  async loadData() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").limit(20)
    this.workouts = [
      { name: '晨间慢跑', imageUrl: '', calories: 320, duration: '30min', level: '初级' },
      { name: 'HIIT燃脂', imageUrl: '', calories: 480, duration: '25min', level: '中级' },
      { name: '全身力量训练', imageUrl: '', calories: 380, duration: '45min', level: '中级' },
      { name: '瑜伽放松', imageUrl: '', calories: 180, duration: '40min', level: '初级' },
      { name: '动感单车', imageUrl: '', calories: 520, duration: '35min', level: '高级' },
      { name: '核心强化', imageUrl: '', calories: 260, duration: '20min', level: '中级' },
    ]
    this.loading = false
  }

  build() {
    Column() {
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 80 })
      } else {
        Scroll() {
          Column() {
            // Body stats dashboard
            Grid() {
              GridItem() {
                StatCard({ label: '今日消耗', value: `${this.dailyCalories}`, unit: 'kcal', icon: '🔥' })
              }
              GridItem() {
                StatCard({ label: '日目标', value: `${this.dailyGoal}`, unit: 'kcal', icon: '🎯' })
              }
              GridItem() {
                StatCard({ label: '本周锻炼', value: `${this.weeklyWorkouts}`, unit: '次', icon: '💪' })
              }
              GridItem() {
                StatCard({ label: '累计时长', value: `${this.totalMinutes}`, unit: 'min', icon: '⏱' })
              }
            }
            .columnsTemplate('1fr 1fr')
            .rowsTemplate('auto')
            .columnsGap(10).rowsGap(10)
            .padding(16)

            // Progress bar
            Column() {
              Row() {
                Text('今日进度').fontSize(14).fontWeight(FontWeight.Medium)
                Blank()
                Text(`${Math.round(this.dailyCalories / this.dailyGoal * 100)}%`)
                  .fontSize(13).fontColor('{{primaryColor}}')
              }.width('100%')
              Row() {
                Column()
                  .width(`${Math.min(this.dailyCalories / this.dailyGoal * 100, 100)}%`)
                  .height(8).backgroundColor('{{primaryColor}}').borderRadius(4)
              }.width('100%').backgroundColor('#f0f0f0').borderRadius(4).margin({ top: 6 })
            }
            .padding(16).backgroundColor(Color.White).borderRadius(12)
            .margin({ left: 16, right: 16, bottom: 12 })

            // Category tabs
            Scroll() {
              Row() {
                ForEach(this.categories, (cat: { id: string, name: string, active: boolean }) => {
                  Text(cat.name)
                    .fontSize(14)
                    .fontColor(cat.active ? Color.White : '#333')
                    .backgroundColor(cat.active ? '{{primaryColor}}' : '#f0f0f0')
                    .borderRadius(16)
                    .padding({ left: 16, right: 16, top: 6, bottom: 6 })
                    .margin({ right: 8 })
                    .onClick(() => {
                      this.activeCategory = cat.id
                      this.categories = this.categories.map(c => ({
                        ...c, active: c.id === cat.id
                      }))
                    })
                })
              }.padding({ left: 16, right: 16 })
            }.height(48).scrollable(ScrollDirection.Horizontal)

            // Workout grid
            if (this.workouts.length === 0) {
              Text('暂无训练计划').fontSize(14).fontColor('#999').padding({ left: 16, bottom: 24 })
            } else {
              Grid() {
                ForEach(this.workouts, (item: {
                  name: string, imageUrl: string,
                  calories: number, duration: string, level: string
                }, index?: number) => {
                  GridItem() {
                    WorkoutCard({
                      name: item.name, imageUrl: item.imageUrl,
                      calories: item.calories, duration: item.duration, level: item.level
                    })
                  }
                })
              }
              .columnsTemplate('1fr 1fr')
              .rowsTemplate('auto')
              .columnsGap(10).rowsGap(10)
              .padding({ left: 16, right: 16, bottom: 24 })
            }
          }
        }.layoutWeight(1)
      }
    }
    .width('100%')
    .height('100%')
  }
}
