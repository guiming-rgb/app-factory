// {{displayName}} — Game Center (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct GameTile {
  @State name: string = ''
  @State coverUrl: string = ''
  @State genre: string = ''
  @State rating: number = 0
  @State playerCount: number = 0
  gameId: string = ''

  build() {
    Column() {
      Image(this.coverUrl || 'https://via.placeholder.com/140')
        .width(140).height(180).borderRadius({ topLeft: 12, topRight: 12 })
        .objectFit(ImageFit.Cover)
      Column() {
        Text(this.name).fontSize(14).fontWeight(FontWeight.Medium).maxLines(1)
          .textOverflow({ overflow: TextOverflow.Ellipsis })
        Text(this.genre).fontSize(11).fontColor('#999').margin({ top: 2 })
        Row() {
          Text(`⭐ ${this.rating}`).fontSize(11).fontColor('#FF9500')
          Blank()
          Text(`${this.playerCount}人`).fontSize(11).fontColor('#999')
        }.width('100%').margin({ top: 4 })
      }.padding(8).alignItems(HorizontalAlign.Start)
    }
    .width(140)
    .backgroundColor(Color.White)
    .borderRadius(12)
    .shadow({ radius: 4, color: '#1a000000', offsetX: 0, offsetY: 2 })
    .margin({ right: 12 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/GameDetail', params: { id: this.gameId } })
    })
  }
}

@Component
export struct LeaderboardRow {
  @State rank: number = 0
  @State playerName: string = ''
  @State score: number = 0
  @State avatar: string = ''

  build() {
    Row() {
      Text(`${this.rank}`)
        .fontSize(16).fontWeight(FontWeight.Bold)
        .fontColor(this.rank <= 3 ? '{{primaryColor}}' : '#999')
        .width(30).textAlign(TextAlign.Center)
      Image(this.avatar || 'https://via.placeholder.com/40')
        .width(40).height(40).borderRadius(20).margin({ left: 8, right: 12 })
      Column() {
        Text(this.playerName).fontSize(15)
        Text(`得分 ${this.score}`).fontSize(12).fontColor('#999').margin({ top: 2 })
      }.alignItems(HorizontalAlign.Start)
      Blank()
      Text(`${this.score}`).fontSize(16).fontWeight(FontWeight.Bold).fontColor('{{primaryColor}}')
    }
    .width('100%').padding({ left: 16, right: 16, top: 10, bottom: 10 })
    .backgroundColor(Color.White).borderRadius(8)
    .margin({ bottom: 6 })
  }
}

@Entry
@Component
struct GameCenterPage {
  @State games: Array<{
    id: string, name: string, coverUrl: string,
    genre: string, rating: number, playerCount: number
  }> = []
  @State leaderboard: Array<{
    id: string, rank: number, playerName: string,
    score: number, avatar: string
  }> = []

  aboutToAppear() {
    this.loadData()
  }

  async loadData() {
    // TODO: Supabase query via {{tableName}}
    this.games = [
      { id: '1', name: '示例游戏 1', coverUrl: '', genre: '休闲', rating: 4.5, playerCount: 1234 },
      { id: '2', name: '示例游戏 2', coverUrl: '', genre: '动作', rating: 4.7, playerCount: 856 },
    ]
    this.leaderboard = [
      { id: '1', rank: 1, playerName: '玩家一', score: 9999, avatar: '' },
      { id: '2', rank: 2, playerName: '玩家二', score: 8888, avatar: '' },
      { id: '3', rank: 3, playerName: '玩家三', score: 7777, avatar: '' },
    ]
  }

  build() {
    Column() {
      // Banner
      Swiper() {
        SwiperItem() {
          Text('新游上线').fontSize(20).fontColor(Color.White).textAlign(TextAlign.Center)
            .width('100%').height(160).backgroundColor('{{primaryColor}}')
        }
        SwiperItem() {
          Text('限时活动').fontSize(20).fontColor(Color.White).textAlign(TextAlign.Center)
            .width('100%').height(160).backgroundColor('#333')
        }
      }
      .height(160)
      .indicatorStyle({ color: '#ffffff80', selectedColor: Color.White })

      // Hot games
      Text('热门游戏').fontSize(18).fontWeight(FontWeight.Bold).width('100%').padding({ left: 16, top: 16 })

      Scroll() {
        Row() {
          ForEach(this.games, (game: {
            id: string, name: string, coverUrl: string,
            genre: string, rating: number, playerCount: number
          }) => {
            GameTile({
              name: game.name, coverUrl: game.coverUrl, genre: game.genre,
              rating: game.rating, playerCount: game.playerCount, gameId: game.id
            })
          })
        }.padding(16)
      }.height(260).scrollable(ScrollDirection.Horizontal)

      // Leaderboard
      Text('排行榜').fontSize(18).fontWeight(FontWeight.Bold).width('100%').padding({ left: 16, top: 8 })

      List() {
        ForEach(this.leaderboard, (entry: {
          id: string, rank: number, playerName: string,
          score: number, avatar: string
        }) => {
          ListItem() {
            LeaderboardRow({ ...entry })
          }
        })
      }
      .layoutWeight(1)
      .padding(16)
    }
    .width('100%')
    .height('100%')
  }
}
