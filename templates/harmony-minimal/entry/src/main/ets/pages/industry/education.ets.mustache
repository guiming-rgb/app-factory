// {{displayName}} — Education / Timetable (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct CourseCard {
  @State name: string = ''
  @State time: string = ''
  @State room: string = ''
  @State teacher: string = ''
  @State color: string = ''
  courseId: string = ''

  build() {
    Column() {
      Row() {
        Column() {
          Text(this.name).fontSize(16).fontWeight(FontWeight.Medium).fontColor(Color.White)
          Text(this.teacher).fontSize(12).fontColor('#ffffffb3').margin({ top: 4 })
        }.alignItems(HorizontalAlign.Start).layoutWeight(1)
        Column() {
          Text(this.time).fontSize(13).fontColor('#ffffffcc')
          Text(this.room).fontSize(12).fontColor('#ffffffb3').margin({ top: 2 })
        }.alignItems(HorizontalAlign.End)
      }
    }
    .width('100%').padding(14)
    .backgroundColor(this.color || '{{primaryColor}}')
    .borderRadius(12)
    .margin({ bottom: 8 })
    .shadow({ radius: 4, color: '#1a000000', offsetX: 0, offsetY: 2 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/CourseDetail', params: { id: this.courseId } })
    })
  }
}

@Component
export struct AssignmentItem {
  @State title: string = ''
  @State courseName: string = ''
  @State deadline: string = ''
  @State urgent: boolean = false

  build() {
    Row() {
      Column() {
        Row() {
          Text(this.urgent ? '!!' : '·').fontSize(16)
            .fontColor(this.urgent ? '#f44336' : '{{primaryColor}}')
            .fontWeight(FontWeight.Bold)
          Text(this.courseName).fontSize(12).fontColor('#999').margin({ left: 4 })
        }
        Text(this.title).fontSize(15).fontWeight(FontWeight.Medium).margin({ top: 4 })
      }.alignItems(HorizontalAlign.Start).layoutWeight(1)
      Column() {
        Text(this.deadline).fontSize(12)
          .fontColor(this.urgent ? '#f44336' : '#666')
        if (this.urgent) {
          Text('紧急').fontSize(10).fontColor(Color.White)
            .backgroundColor('#f44336').borderRadius(6)
            .padding({ left: 6, right: 6, top: 2, bottom: 2 }).margin({ top: 4 })
        }
      }.alignItems(HorizontalAlign.End)
    }
    .width('100%').padding(14).backgroundColor(Color.White).borderRadius(10)
    .margin({ bottom: 6 })
    .shadow({ radius: 2, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/AssignmentDetail', params: { id: this.title } })
    })
  }
}

@Entry
@Component
struct EducationPage {
  @State weekdays: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'mon', name: '周一', active: true },
    { id: 'tue', name: '周二', active: false },
    { id: 'wed', name: '周三', active: false },
    { id: 'thu', name: '周四', active: false },
    { id: 'fri', name: '周五', active: false },
    { id: 'sat', name: '周六', active: false },
    { id: 'sun', name: '周日', active: false },
  ]
  @State activeDay: string = 'mon'
  @State courses: Array<{
    id: string, name: string, time: string,
    room: string, teacher: string, color: string, day: string
  }> = []
  @State assignments: Array<{
    id: string, title: string, courseName: string,
    deadline: string, urgent: boolean
  }> = []
  @State attendanceRate: number = 94
  @State loading: boolean = false

  aboutToAppear() {
    this.loadData()
  }

  async loadData() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").limit(30)
    this.courses = [
      { id: '1', name: '高等数学', time: '08:00-09:40', room: '教学楼301', teacher: '李教授', color: '#1565c0', day: 'mon' },
      { id: '2', name: '英语读写', time: '10:00-11:40', room: '外语楼203', teacher: '王老师', color: '#2e7d32', day: 'mon' },
      { id: '3', name: '数据结构', time: '14:00-15:40', room: '实验楼405', teacher: '张教授', color: '#6a1b9a', day: 'mon' },
      { id: '4', name: '线性代数', time: '08:00-09:40', room: '教学楼302', teacher: '陈教授', color: '#e65100', day: 'tue' },
      { id: '5', name: '大学物理', time: '10:00-11:40', room: '物理楼101', teacher: '刘教授', color: '#c62828', day: 'tue' },
      { id: '6', name: '操作系统', time: '08:00-09:40', room: '实验楼301', teacher: '赵教授', color: '#1565c0', day: 'wed' },
      { id: '7', name: '计算机网络', time: '14:00-15:40', room: '实验楼302', teacher: '孙老师', color: '#2e7d32', day: 'wed' },
      { id: '8', name: '软件开发实践', time: '10:00-11:40', room: '实训中心', teacher: '周老师', color: '#6a1b9a', day: 'thu' },
      { id: '9', name: '概率论', time: '08:00-09:40', room: '教学楼303', teacher: '吴教授', color: '#e65100', day: 'fri' },
    ]
    this.assignments = [
      { id: '1', title: '微积分课后习题第三章', courseName: '高等数学', deadline: '明天 23:59', urgent: true },
      { id: '2', title: '数据结构项目设计报告', courseName: '数据结构', deadline: '3天后', urgent: false },
      { id: '3', title: '英语作文：环境保护', courseName: '英语读写', deadline: '下周 23:59', urgent: false },
      { id: '4', title: '物理实验数据处理', courseName: '大学物理', deadline: '还剩2天', urgent: true },
    ]
    this.loading = false
  }

  get dayCourses(): Array<{
    id: string, name: string, time: string,
    room: string, teacher: string, color: string, day: string
  }> {
    return this.courses.filter(c => c.day === this.activeDay)
  }

  build() {
    Column() {
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 80 })
      } else {
        Scroll() {
          Column() {
            // Attendance header card
            Row() {
              Column() {
                Text('出勤率').fontSize(13).fontColor('#ffffffb3')
                Text(`${this.attendanceRate}%`).fontSize(32).fontWeight(FontWeight.Bold)
                  .fontColor(Color.White).margin({ top: 4 })
              }.alignItems(HorizontalAlign.Center).layoutWeight(1)
              Column() {
                Text('今日课程').fontSize(13).fontColor('#ffffffb3')
                Text(`${this.dayCourses.length}`).fontSize(32).fontWeight(FontWeight.Bold)
                  .fontColor(Color.White).margin({ top: 4 })
              }.alignItems(HorizontalAlign.Center).layoutWeight(1)
              Column() {
                Text('待提交').fontSize(13).fontColor('#ffffffb3')
                Text(`${this.assignments.filter(a => a.urgent).length}`).fontSize(32).fontWeight(FontWeight.Bold)
                  .fontColor('#ffcdd2').margin({ top: 4 })
              }.alignItems(HorizontalAlign.Center).layoutWeight(1)
            }
            .width('100%').padding(20)
            .backgroundColor('{{primaryColor}}')
            .borderRadius({ bottomLeft: 20, bottomRight: 20 })

            // Weekday tabs
            Scroll() {
              Row() {
                ForEach(this.weekdays, (day: { id: string, name: string, active: boolean }) => {
                  Text(day.name)
                    .fontSize(14)
                    .fontColor(day.active ? Color.White : '#333')
                    .backgroundColor(day.active ? '{{primaryColor}}' : '#f0f0f0')
                    .borderRadius(16)
                    .padding({ left: 14, right: 14, top: 6, bottom: 6 })
                    .margin({ right: 6 })
                    .onClick(() => {
                      this.activeDay = day.id
                      this.weekdays = this.weekdays.map(d => ({
                        ...d, active: d.id === day.id
                      }))
                    })
                })
              }.padding(16)
            }.height(48).scrollable(ScrollDirection.Horizontal)

            // Courses for selected day
            Text('课程安排').fontSize(18).fontWeight(FontWeight.Bold).width('100%').padding({ left: 16, bottom: 8 })

            if (this.dayCourses.length === 0) {
              Text('今日无课').fontSize(14).fontColor('#999').padding({ left: 16, bottom: 16 })
            } else {
              List() {
                ForEach(this.dayCourses, (course: {
                  id: string, name: string, time: string,
                  room: string, teacher: string, color: string, day: string
                }) => {
                  ListItem() {
                    CourseCard({
                      name: course.name, time: course.time,
                      room: course.room, teacher: course.teacher,
                      color: course.color, courseId: course.id
                    })
                  }
                })
              }
              .padding({ left: 16, right: 16 })
            }

            // Assignments
            Row() {
              Text('待办作业').fontSize(18).fontWeight(FontWeight.Bold)
              Blank()
              Text(`${this.assignments.filter(a => a.urgent).length}条紧急`)
                .fontSize(12).fontColor('#f44336')
            }.width('100%').padding({ left: 16, top: 16, right: 16, bottom: 8 })

            if (this.assignments.length === 0) {
              Text('暂无作业').fontSize(14).fontColor('#999').padding({ left: 16, bottom: 24 })
            } else {
              List() {
                ForEach(this.assignments, (item: {
                  id: string, title: string, courseName: string,
                  deadline: string, urgent: boolean
                }) => {
                  ListItem() {
                    AssignmentItem({ ...item })
                  }
                })
              }
              .padding({ left: 16, right: 16, bottom: 24 })
            }
          }
        }.layoutWeight(1)
      }
    }
    .width('100%')
    .height('100%')
  }
}
