// {{displayName}} — Video Platform (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct VideoCard {
  @State title: string = ''
  @State thumbnailUrl: string = ''
  @State duration: string = ''
  @State views: number = 0
  @State rating: number = 0
  @State author: string = ''
  videoId: string = ''

  build() {
    Column() {
      Stack() {
        Image(this.thumbnailUrl || 'https://via.placeholder.com/320x180')
          .width('100%').height(120).objectFit(ImageFit.Cover)
          .borderRadius({ topLeft: 10, topRight: 10 })
        Text(this.duration)
          .fontSize(11).fontColor(Color.White).backgroundColor('#cc000000')
          .borderRadius(4).padding({ left: 6, right: 6, top: 2, bottom: 2 })
          .position({ bottom: 6, right: 6 })
      }.width('100%')
      Column() {
        Text(this.title).fontSize(14).fontWeight(FontWeight.Medium).maxLines(2)
          .lineHeight(18).textOverflow({ overflow: TextOverflow.Ellipsis }).width('100%')
        Row() {
          Text(this.author).fontSize(11).fontColor('#999')
          Blank()
          Text(`${this.views}次播放`).fontSize(11).fontColor('#999')
        }.width('100%').margin({ top: 4 })
        Row() {
          Text(`⭐ ${this.rating}`).fontSize(11).fontColor('#FF9500')
        }.width('100%').margin({ top: 2 })
      }.padding(8).alignItems(HorizontalAlign.Start)
    }
    .width('100%').backgroundColor(Color.White).borderRadius(10)
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/VideoPlayer', params: { id: this.videoId } })
    })
  }
}

@Entry
@Component
struct VideoPage {
  @State videos: Array<{
    id: string, title: string, thumbnailUrl: string,
    duration: string, views: number, rating: number, author: string
  }> = []
  @State categories: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '全部', active: true },
    { id: 'recommend', name: '推荐', active: false },
    { id: 'music', name: '音乐', active: false },
    { id: 'game', name: '游戏', active: false },
    { id: 'tech', name: '科技', active: false },
  ]
  @State activeCategory: string = 'all'
  @State loading: boolean = false

  aboutToAppear() {
    this.loadVideos()
  }

  async loadVideos() {
    this.loading = true
    try {
      const result = await videoService.list();
      if (result && result.length > 0) {
        this.videos = result;
      }
    } catch (e) {
      // 加载失败
    } finally {
      this.loading = false;
    }
  }

  build() {
    Column() {
      // Header
      Text('{{displayName}}')
        .fontSize(20).fontWeight(FontWeight.Bold).width('100%').padding(16)

      // Category tabs
      Scroll() {
        Row() {
          ForEach(this.categories, (cat: { id: string, name: string, active: boolean }) => {
            Text(cat.name)
              .fontSize(14)
              .fontColor(cat.active ? Color.White : '#333')
              .backgroundColor(cat.active ? '{{primaryColor}}' : '#f0f0f0')
              .borderRadius(16)
              .padding({ left: 16, right: 16, top: 6, bottom: 6 })
              .margin({ right: 8 })
              .onClick(() => {
                this.activeCategory = cat.id
                this.categories = this.categories.map(c => ({
                  ...c, active: c.id === cat.id
                }))
                this.loadVideos()
              })
          })
        }.padding({ left: 16, right: 16 })
      }.height(44).scrollable(ScrollDirection.Horizontal)

      // Content
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 60 })
      } else if (this.videos.length === 0) {
        Column() {
          Text('暂无视频').fontSize(16).fontColor('#999')
        }.width('100%').margin({ top: 60 })
      } else {
        Grid() {
          ForEach(this.videos, (item: {
            id: string, title: string, thumbnailUrl: string,
            duration: string, views: number, rating: number, author: string
          }, index?: number) => {
            GridItem() {
              VideoCard({
                title: item.title, thumbnailUrl: item.thumbnailUrl,
                duration: item.duration, views: item.views,
                rating: item.rating, author: item.author, videoId: item.id
              })
            }
          })
        }
        .columnsTemplate('1fr 1fr')
        .rowsTemplate('auto')
        .columnsGap(10).rowsGap(10)
        .padding(16)
      }
    }
    .width('100%')
    .height('100%')
  }
}
