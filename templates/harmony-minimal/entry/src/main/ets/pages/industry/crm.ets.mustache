// {{displayName}} — CRM Client Management (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct ClientCard {
  @State name: string = ''
  @State company: string = ''
  @State dealValue: number = 0
  @State stage: string = ''
  @State stageLabel: string = ''
  @State avatarUrl: string = ''
  clientId: string = ''

  stageBgColor(): string {
    const colors: Record<string, string> = {
      'lead': '#e3f2fd',
      'contact': '#fce4ec',
      'need': '#f3e5f5',
      'quote': '#fff3e0',
      'negotiate': '#e8f5e9',
      'closed': '#e8f5e9',
    }
    return colors[this.stage] || '#f5f5f5'
  }

  stageTextColor(): string {
    const colors: Record<string, string> = {
      'lead': '#1976d2',
      'contact': '#c62828',
      'need': '#7b1fa2',
      'quote': '#e65100',
      'negotiate': '#2e7d32',
      'closed': '#2e7d32',
    }
    return colors[this.stage] || '#999'
  }

  build() {
    Row() {
      Image(this.avatarUrl || 'https://via.placeholder.com/48')
        .width(48).height(48).borderRadius(24).objectFit(ImageFit.Cover)
      Column() {
        Row() {
          Text(this.name).fontSize(16).fontWeight(FontWeight.Medium)
          Text(this.stageLabel)
            .fontSize(11)
            .fontColor(this.stageTextColor())
            .backgroundColor(this.stageBgColor())
            .borderRadius(8)
            .padding({ left: 8, right: 8, top: 2, bottom: 2 })
            .margin({ left: 8 })
        }
        Text(this.company).fontSize(13).fontColor('#666').margin({ top: 3 })
        Text(`意向价值: ¥${this.dealValue.toLocaleString()}`)
          .fontSize(13).fontWeight(FontWeight.Medium).fontColor('{{primaryColor}}').margin({ top: 2 })
      }
      .alignItems(HorizontalAlign.Start)
      .layoutWeight(1)
      .margin({ left: 12 })
    }
    .width('100%').padding(14).backgroundColor(Color.White).borderRadius(12)
    .margin({ bottom: 8 })
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/ClientDetail', params: { id: this.clientId } })
    })
  }
}

@Entry
@Component
struct CRMPage {
  @State clients: Array<{
    id: string, name: string, company: string,
    dealValue: number, stage: string, stageLabel: string, avatarUrl: string
  }> = []
  @State stages: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '全部', active: true },
    { id: 'lead', name: '线索', active: false },
    { id: 'contact', name: '接触', active: false },
    { id: 'need', name: '需求', active: false },
    { id: 'quote', name: '报价', active: false },
    { id: 'negotiate', name: '谈判', active: false },
    { id: 'closed', name: '成交', active: false },
  ]
  @State activeStage: string = 'all'
  @State keyword: string = ''
  @State totalDealValue: number = 0
  @State loading: boolean = false
  private searchController: TextInputController = new TextInputController()

  aboutToAppear() {
    this.loadClients()
  }

  async loadClients() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").order("deal_value", { ascending: false }).limit(50)
    this.clients = [
      { id: '1', name: '张三', company: '示例科技有限公司', dealValue: 50000, stage: 'negotiate', stageLabel: '谈判', avatarUrl: '' },
      { id: '2', name: '李四', company: '创新企业集团', dealValue: 120000, stage: 'quote', stageLabel: '报价', avatarUrl: '' },
      { id: '3', name: '王五', company: '数据驱动有限公司', dealValue: 30000, stage: 'need', stageLabel: '需求', avatarUrl: '' },
      { id: '4', name: '赵六', company: '未来科技股份', dealValue: 80000, stage: 'lead', stageLabel: '线索', avatarUrl: '' },
      { id: '5', name: '陈七', company: '星辰互联网公司', dealValue: 200000, stage: 'closed', stageLabel: '成交', avatarUrl: '' },
      { id: '6', name: '刘八', company: '智慧解决方案集团', dealValue: 15000, stage: 'contact', stageLabel: '接触', avatarUrl: '' },
    ]
    this.totalDealValue = this.clients.reduce((s, c) => s + c.dealValue, 0)
    this.loading = false
  }

  get filteredClients(): Array<{
    id: string, name: string, company: string,
    dealValue: number, stage: string, stageLabel: string, avatarUrl: string
  }> {
    let result = this.clients
    if (this.activeStage !== 'all') {
      result = result.filter(c => c.stage === this.activeStage)
    }
    if (this.keyword.length > 0) {
      result = result.filter(c =>
        c.name.includes(this.keyword) || c.company.includes(this.keyword)
      )
    }
    return result
  }

  build() {
    Column() {
      // Header summary
      Column() {
        Text('商机总额').fontSize(13).fontColor('#ffffffb3')
        Text(`¥${this.totalDealValue.toLocaleString()}`)
          .fontSize(28).fontWeight(FontWeight.Bold).fontColor(Color.White).margin({ top: 4 })
      }
      .width('100%').padding(20)
      .backgroundColor('{{primaryColor}}')
      .borderRadius({ bottomLeft: 20, bottomRight: 20 })

      // Search bar
      TextInput({ placeholder: '搜索客户姓名或公司...', controller: this.searchController })
        .height(40).backgroundColor('#f5f5f5').borderRadius(20)
        .padding({ left: 16, right: 16 }).margin({ left: 16, right: 16, top: 12 })
        .onChange((v: string) => { this.keyword = v })

      // Stage tabs
      Scroll() {
        Row() {
          ForEach(this.stages, (stage: { id: string, name: string, active: boolean }) => {
            Text(stage.name)
              .fontSize(13)
              .fontColor(stage.active ? Color.White : '#333')
              .backgroundColor(stage.active ? '{{primaryColor}}' : '#f0f0f0')
              .borderRadius(16)
              .padding({ left: 14, right: 14, top: 5, bottom: 5 })
              .margin({ right: 6 })
              .onClick(() => {
                this.activeStage = stage.id
                this.stages = this.stages.map(s => ({
                  ...s, active: s.id === stage.id
                }))
              })
          })
        }.padding(16)
      }.height(48).scrollable(ScrollDirection.Horizontal)

      // Client list
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 40 })
      } else if (this.filteredClients.length === 0) {
        Column() {
          Text('暂无匹配客户').fontSize(15).fontColor('#999')
        }.width('100%').margin({ top: 60 })
      } else {
        List() {
          ForEach(this.filteredClients, (item: {
            id: string, name: string, company: string,
            dealValue: number, stage: string, stageLabel: string, avatarUrl: string
          }) => {
            ListItem() {
              ClientCard({ ...item, clientId: item.id })
            }
          })
        }
        .layoutWeight(1)
        .padding({ left: 16, right: 16, top: 4 })
      }
    }
    .width('100%')
    .height('100%')
  }
}
