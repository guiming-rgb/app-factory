// {{displayName}} — Recruitment / Job Board (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct JobCard {
  @State title: string = ''
  @State company: string = ''
  @State companyLogo: string = ''
  @State salaryMin: number = 0
  @State salaryMax: number = 0
  @State city: string = ''
  @State experience: string = ''
  @State tags: string[] = []
  jobId: string = ''

  build() {
    Column() {
      Row() {
        Image(this.companyLogo || 'https://via.placeholder.com/48')
          .width(48).height(48).borderRadius(10).objectFit(ImageFit.Cover)
        Column() {
          Text(this.title).fontSize(16).fontWeight(FontWeight.Medium)
            .maxLines(1).textOverflow({ overflow: TextOverflow.Ellipsis })
          Text(this.company).fontSize(13).fontColor('#666').margin({ top: 3 })
          Row() {
            Text(this.city).fontSize(12).fontColor('#999')
            Text(` ${this.experience}`).fontSize(12).fontColor('#999').margin({ left: 8 })
          }.margin({ top: 2 })
        }
        .alignItems(HorizontalAlign.Start)
        .layoutWeight(1)
        .margin({ left: 12 })
      }

      Row() {
        Text(`${this.salaryMin}k-${this.salaryMax}k`)
          .fontSize(17).fontWeight(FontWeight.Bold).fontColor('{{primaryColor}}')
        Text('· 月薪').fontSize(11).fontColor('#999').margin({ left: 4 })
        Blank()
        Button('立即申请')
          .height(32).fontSize(13).fontColor(Color.White)
          .backgroundColor('{{primaryColor}}').borderRadius(16)
          .padding({ left: 16, right: 16 })
          .onClick(() => {
            router.pushUrl({ url: 'pages/JobApply', params: { id: this.jobId } })
          })
      }.width('100%').margin({ top: 10 })

      if (this.tags.length > 0) {
        Scroll() {
          Row() {
            ForEach(this.tags, (tag: string) => {
              Text(tag)
                .fontSize(11).fontColor('{{primaryColor}}')
                .backgroundColor('{{primaryColor}}1a')
                .borderRadius(8).padding({ left: 8, right: 8, top: 3, bottom: 3 })
                .margin({ right: 6 })
            })
          }
        }.scrollable(ScrollDirection.Horizontal).height(28).margin({ top: 8 })
      }
    }
    .width('100%').padding(16).backgroundColor(Color.White).borderRadius(12)
    .margin({ bottom: 10 })
    .shadow({ radius: 3, color: '#1a000000', offsetX: 0, offsetY: 1 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/JobDetail', params: { id: this.jobId } })
    })
  }
}

@Entry
@Component
struct RecruitmentPage {
  @State jobs: Array<{
    id: string, title: string, company: string, companyLogo: string,
    salaryMin: number, salaryMax: number, city: string,
    experience: string, tags: string[]
  }> = []
  @State keyword: string = ''
  @State minSalary: string = ''
  @State maxSalary: string = ''
  @State cities: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '全部', active: true },
    { id: 'beijing', name: '北京', active: false },
    { id: 'shanghai', name: '上海', active: false },
    { id: 'shenzhen', name: '深圳', active: false },
    { id: 'hangzhou', name: '杭州', active: false },
  ]
  @State activeCity: string = 'all'
  @State loading: boolean = false
  private searchController: TextInputController = new TextInputController()

  aboutToAppear() {
    this.loadJobs()
  }

  async loadJobs() {
    this.loading = true
    // TODO: Supabase query via {{tableName}}
    // const { data } = await supabase.from("{{tableName}}").select("*").order("salary_max", { ascending: false }).limit(20)
    this.jobs = [
      { id: '1', title: '高级前端开发工程师', company: '示例科技有限公司', companyLogo: '', salaryMin: 25, salaryMax: 40, city: '北京', experience: '3-5年', tags: ['React', 'TypeScript', 'ArkTS'] },
      { id: '2', title: '后端架构师', company: '数据驱动有限公司', companyLogo: '', salaryMin: 35, salaryMax: 55, city: '上海', experience: '5-10年', tags: ['Go', '微服务', 'Kubernetes'] },
      { id: '3', title: '产品经理', company: '创新企业集团', companyLogo: '', salaryMin: 20, salaryMax: 35, city: '深圳', experience: '3-5年', tags: ['策略', '数据驱动', '敏捷'] },
      { id: '4', title: 'UI/UX设计师', company: '未来科技股份', companyLogo: '', salaryMin: 18, salaryMax: 30, city: '杭州', experience: '2-4年', tags: ['Figma', '交互设计', '设计系统'] },
      { id: '5', title: '测试开发工程师', company: '星辰互联网公司', companyLogo: '', salaryMin: 20, salaryMax: 32, city: '北京', experience: '3-5年', tags: ['自动化测试', 'Python', 'CI/CD'] },
      { id: '6', title: 'Flutter开发工程师', company: '智慧解决方案集团', companyLogo: '', salaryMin: 22, salaryMax: 38, city: '上海', experience: '2-5年', tags: ['Flutter', 'Dart', '跨平台'] },
    ]
    this.loading = false
  }

  get filteredJobs(): Array<{
    id: string, title: string, company: string, companyLogo: string,
    salaryMin: number, salaryMax: number, city: string,
    experience: string, tags: string[]
  }> {
    let result = this.jobs
    if (this.keyword.length > 0) {
      result = result.filter(j =>
        j.title.includes(this.keyword) || j.company.includes(this.keyword) ||
        j.tags.some(t => t.includes(this.keyword))
      )
    }
    if (this.activeCity !== 'all') {
      const cityName = this.cities.find(c => c.id === this.activeCity)?.name || ''
      result = result.filter(j => j.city === cityName)
    }
    const minS = parseInt(this.minSalary)
    const maxS = parseInt(this.maxSalary)
    if (!isNaN(minS)) {
      result = result.filter(j => j.salaryMax >= minS)
    }
    if (!isNaN(maxS)) {
      result = result.filter(j => j.salaryMin <= maxS)
    }
    return result
  }

  build() {
    Column() {
      // Header
      Column() {
        Text('{{displayName}}').fontSize(20).fontWeight(FontWeight.Bold).fontColor(Color.White)
        Text('发现好工作').fontSize(13).fontColor('#ffffffb3').margin({ top: 4 })
      }
      .width('100%').padding(24)
      .backgroundColor('{{primaryColor}}')
      .borderRadius({ bottomLeft: 20, bottomRight: 20 })

      // Search bar
      Row() {
        TextInput({ placeholder: '搜索职位、公司或技能...', controller: this.searchController })
          .layoutWeight(1).height(42).backgroundColor('#f5f5f5').borderRadius(21)
          .padding({ left: 16, right: 16 })
          .onChange((v: string) => { this.keyword = v })
        Button('搜索').backgroundColor('{{primaryColor}}').fontColor(Color.White)
          .borderRadius(21).margin({ left: 8 })
          .onClick(() => {})
      }.padding({ left: 16, right: 16, top: 12 })

      // Salary filter
      Row() {
        TextInput({ placeholder: '最低薪资', controller: new TextInputController() })
          .height(36).backgroundColor('#f5f5f5').borderRadius(18).width(100)
          .padding({ left: 12, right: 12 }).fontSize(13)
          .onChange((v: string) => { this.minSalary = v })
        Text('—').fontSize(14).fontColor('#999').margin({ left: 8, right: 8 })
        TextInput({ placeholder: '最高薪资', controller: new TextInputController() })
          .height(36).backgroundColor('#f5f5f5').borderRadius(18).width(100)
          .padding({ left: 12, right: 12 }).fontSize(13)
          .onChange((v: string) => { this.maxSalary = v })
        Text('k/月').fontSize(13).fontColor('#999').margin({ left: 6 })
      }.width('100%').padding({ left: 16, right: 16, top: 8 })

      // City tabs
      Scroll() {
        Row() {
          ForEach(this.cities, (city: { id: string, name: string, active: boolean }) => {
            Text(city.name)
              .fontSize(13)
              .fontColor(city.active ? Color.White : '#333')
              .backgroundColor(city.active ? '{{primaryColor}}' : '#f0f0f0')
              .borderRadius(16)
              .padding({ left: 14, right: 14, top: 5, bottom: 5 })
              .margin({ right: 6 })
              .onClick(() => {
                this.activeCity = city.id
                this.cities = this.cities.map(c => ({
                  ...c, active: c.id === city.id
                }))
              })
          })
        }.padding(16)
      }.height(44).scrollable(ScrollDirection.Horizontal)

      // Job list
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 40 })
      } else if (this.filteredJobs.length === 0) {
        Column() {
          Text('暂无匹配职位').fontSize(15).fontColor('#999')
          Text('试试调整搜索条件').fontSize(13).fontColor('#bbb').margin({ top: 6 })
        }.width('100%').margin({ top: 60 })
      } else {
        List() {
          ForEach(this.filteredJobs, (item: {
            id: string, title: string, company: string, companyLogo: string,
            salaryMin: number, salaryMax: number, city: string,
            experience: string, tags: string[]
          }) => {
            ListItem() {
              JobCard({ ...item, jobId: item.id })
            }
          })
        }
        .layoutWeight(1)
        .padding({ left: 16, right: 16, top: 4, bottom: 16 })
      }
    }
    .width('100%')
    .height('100%')
  }
}
