// {{displayName}} — Food Delivery Restaurant List (Mustache template)
// Variables: displayName, primaryColor, tableName

import router from '@ohos.router';

@Component
export struct RestaurantCard {
  @State name: string = ''
  @State logoUrl: string = ''
  @State rating: number = 0
  @State deliveryTime: string = ''
  @State deliveryFee: string = ''
  @State cuisineTags: string[] = []
  restaurantId: string = ''

  build() {
    Row() {
      Image(this.logoUrl || 'https://via.placeholder.com/80')
        .width(80).height(80).borderRadius(12).objectFit(ImageFit.Cover)
      Column() {
        Text(this.name).fontSize(17).fontWeight(FontWeight.Medium)
        Row() {
          ForEach(this.cuisineTags, (tag: string) => {
            Text(tag)
              .fontSize(11).fontColor('{{primaryColor}}')
              .backgroundColor('{{primaryColor}}1a')
              .borderRadius(8).padding({ left: 6, right: 6, top: 2, bottom: 2 })
              .margin({ right: 4 })
          })
        }.margin({ top: 6 })
        Row() {
          Text(`⭐ ${this.rating}`).fontSize(13).fontColor('#FF9500')
          Text(this.deliveryTime).fontSize(12).fontColor('#666').margin({ left: 12 })
          Text(this.deliveryFee).fontSize(12).fontColor('#666').margin({ left: 8 })
        }.margin({ top: 4 })
      }.alignItems(HorizontalAlign.Start).layoutWeight(1).margin({ left: 12 })
    }
    .width('100%')
    .padding(12)
    .backgroundColor(Color.White)
    .borderRadius(12)
    .margin({ bottom: 8 })
    .onClick(() => {
      router.pushUrl({ url: 'pages/RestaurantDetail', params: { id: this.restaurantId } })
    })
  }
}

@Entry
@Component
struct FoodDeliveryPage {
  @State restaurants: Array<{
    id: string, name: string, logoUrl: string,
    rating: number, deliveryTime: string, deliveryFee: string,
    cuisineTags: string[]
  }> = []
  @State categories: Array<{ id: string, name: string, active: boolean }> = [
    { id: 'all', name: '全部', active: true },
    { id: 'chinese', name: '中餐', active: false },
    { id: 'western', name: '西餐', active: false },
    { id: 'japanese', name: '日料', active: false },
  ]
  @State activeCategory: string = 'all'
  @State loading: boolean = false

  aboutToAppear() {
    this.loadRestaurants()
  }

  async loadRestaurants() {
    this.loading = true
    try {
      const result = await foodService.list();
      if (result && result.length > 0) {
        this.restaurants = result;
      }
    } catch (e) {
      // 加载失败
    } finally {
      this.loading = false;
    }
  }

  build() {
    Column() {
      // Search
      TextInput({ placeholder: '搜索餐厅或菜品' })
        .height(40).backgroundColor('#f5f5f5').borderRadius(20)
        .padding({ left: 16, right: 16 }).margin({ left: 16, right: 16, top: 12 })

      // Categories
      Scroll() {
        Row() {
          ForEach(this.categories, (cat: { id: string, name: string, active: boolean }) => {
            Text(cat.name)
              .fontSize(14)
              .fontColor(cat.active ? Color.White : '#333')
              .backgroundColor(cat.active ? '{{primaryColor}}' : '#f0f0f0')
              .borderRadius(16)
              .padding({ left: 16, right: 16, top: 6, bottom: 6 })
              .margin({ right: 8 })
              .onClick(() => {
                this.activeCategory = cat.id
                this.categories = this.categories.map(c => ({
                  ...c, active: c.id === cat.id
                }))
                this.loadRestaurants()
              })
          })
        }.padding(16)
      }.height(48).scrollable(ScrollDirection.Horizontal)

      // Restaurant list
      if (this.loading) {
        LoadingProgress().width(32).height(32).margin({ top: 60 })
      } else {
        List() {
          ForEach(this.restaurants, (item: {
            id: string, name: string, logoUrl: string,
            rating: number, deliveryTime: string, deliveryFee: string,
            cuisineTags: string[]
          }) => {
            ListItem() {
              RestaurantCard({ ...item, restaurantId: item.id })
            }
          })
        }
        .layoutWeight(1)
        .padding(16)
      }
    }
    .width('100%')
    .height('100%')
  }
}
