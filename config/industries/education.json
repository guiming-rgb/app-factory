{
  "id": "education",
  "pilot": true,
  "templateDir": "industry-education",
  "entities": [
    "courses"
  ],
  "displayName": "课程助手",
  "tableName": "courses",
  "primaryColor": "Color(0xFF0D9488)",
  "hasImage": false,
  "serviceName": "educationService",
  "widgetClasses": [
    "TimetableCell"
  ],
  "serviceMethods": [
    "getAssignments",
    "getGrades",
    "getTodaySchedule"
  ],
  "harmonyMethods": [
    {
      "name": "getAssignments",
      "table": "assignments",
      "verb": "GET",
      "path": "?course_id=eq.{{courseId}}&order=deadline",
      "params": [{ "name": "courseId" }]
    },
    {
      "name": "getGrades",
      "table": "grades",
      "verb": "GET",
      "path": "?course_id=eq.{{courseId}}&order=created_at.desc",
      "params": [{ "name": "courseId" }]
    }
  ]
}
