page {
  background-color: #f5f5f5;
  color: #1f2937;
  font-size: 28rpx;
  line-height: 1.5;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.empty {
  margin-top: 120rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.muted {
  color: #9ca3af;
  font-size: 24rpx;
}
