<view class="page">
  <privacy-popup show="{{showPrivacy}}" bind:accept="onPrivacyAccept" />

  <view class="card">
    <view class="todo-title">记一笔</view>
    <view class="muted">填写以下信息并提交</view>
  </view>

  <view class="card">
    <view class="form-row">
      <text class="form-label">title</text>
      <input class="form-input" placeholder="请输入title" value="{{form.title}}" bindinput="onFieldInput" data-field="title" />
    </view>
    <view class="form-row">
      <text class="form-label">amount</text>
      <input class="form-input" placeholder="请输入amount" value="{{form.amount}}" bindinput="onFieldInput" data-field="amount" type="digit" />
    </view>
    <view class="form-row">
      <text class="form-label">created_at</text>
      <input class="form-input" placeholder="请输入created_at" value="{{form.created_at}}" bindinput="onFieldInput" data-field="created_at" />
    </view>
  </view>

  <view class="card">
    <button type="primary" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '提交中…' : '提交'}}
    </button>
  </view>

  <view class="card" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
  </view>
</view>