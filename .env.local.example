# --- 安全提示（必读）---
# 1. 切勿把 OPENAI_API_KEY、SUPABASE_SERVICE_ROLE_KEY、INNGEST_SIGNING_KEY 等加上 NEXT_PUBLIC_ 前缀（会被打包进浏览器）。
# 2. 本文件复制为 .env.local 后勿提交 Git（仓库已 .gitignore）。
# 3. 生产环境须配合 HTTPS + 登录鉴权 + Supabase RLS；当前 MVP 无用户隔离，勿对公网裸奔长期开放。

NEXT_PUBLIC_SUPABASE_URL=你的_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=你的_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=你的_supabase_service_role_key

# 代码生成产物 Storage（P2；默认 bucket 名 codegen-artifacts，首次上传时自动创建）
# SUPABASE_STORAGE_BUCKET=codegen-artifacts
# 设为 1 则仅写本地 /tmp，不上传 Storage：
# CODEGEN_STORAGE_DISABLED=1

# v2.1 codegen 流水线 Docker analyze（本地需 Docker Desktop）
# CODEGEN_DOCKER_ANALYZE_DISABLED=1
# 单次超时 ms（默认 120000）；超时/ETIMEDOUT 可重试次数（默认 2）：
# CODEGEN_DOCKER_ANALYZE_TIMEOUT_MS=120000
# CODEGEN_DOCKER_ANALYZE_RETRIES=2
# analyze 失败时仍标记 completed（默认 strict 会 failed）：
# CODEGEN_DOCKER_ANALYZE_STRICT=0

# v2.1 自动修错 Agent（analyze 失败时 LLM patch，默认最多 3 轮）
# CODEGEN_AUTOFIX_DISABLED=1
# CODEGEN_AUTOFIX_MAX_ROUNDS=3

# v2.1 小程序结构门禁（JSON/JS 校验，无需微信开发者工具 GUI）
# CODEGEN_WECHAT_BUILD_DISABLED=1
# CODEGEN_WECHAT_BUILD_STRICT=0

# v4-6 API 限流（每小时次数；0=关闭限流）
# RATE_LIMIT_GENERATE_PER_HOUR=10
# RATE_LIMIT_CODEGEN_PER_HOUR=20

# C4 GitHub OAuth + 产物 push（在 GitHub → Settings → Developer settings → OAuth Apps 创建）
# 回调 URL：{NEXT_PUBLIC_APP_URL}/api/github/oauth/callback
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_SCOPES=repo read:user
# GITHUB_OAUTH_DISABLED=1
# GITHUB_OAUTH_STATE_SECRET=可选_随机字符串

# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-xxx.pooler.supabase.com:6543/postgres

OPENAI_API_KEY=你的_api_key
# 国内首选：DeepSeek（OpenAI 兼容）。豆包 / 通义千问等请填各厂商文档中的 base URL 与模型名。
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat
# 境外示例（非首选，仅作备用）：OPENAI_BASE_URL=https://api.openai.com/v1 ； OPENAI_MODEL=gpt-4o-mini

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Inngest：本地双进程联调必须加下一行，否则会出现「cloud mode but no signing key」且 PUT /api/inngest 500
INNGEST_DEV=1
# 上云后再关掉 INNGEST_DEV，并改用 Inngest Cloud 提供的密钥：
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
